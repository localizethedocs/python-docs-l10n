msgstr ""

#: ../../../deprecations/pending-removal-in-3.16.rst:99
msgid ""
"The :func:`!_enablelegacywindowsfsencoding` function has been deprecated "
"since Python 3.13. Use the :envvar:`PYTHONLEGACYWINDOWSFSENCODING` "
"environment variable instead."
msgstr ""

