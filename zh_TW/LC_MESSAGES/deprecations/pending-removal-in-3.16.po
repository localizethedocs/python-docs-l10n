msgid ":mod:`symtable`:"
msgstr ""

#: ../../../deprecations/pending-removal-in-3.16.rst:94
msgid ""
"The :meth:`!symtable.Class.get_methods` method has been deprecated since "
"Python 3.14."
msgstr ""

