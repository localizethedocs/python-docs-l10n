msgid ":mod:`argparse`:"
msgstr ""

#: ../../../deprecations/pending-removal-in-future.rst:9
msgid ""
"Nesting argument groups and nesting mutually exclusive groups are deprecated."
msgstr ""

#: ../../../deprecations/pending-removal-in-future.rst:11
