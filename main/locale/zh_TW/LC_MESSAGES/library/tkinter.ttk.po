msgstr ""

#: ../../../library/tkinter.ttk.rst:195
msgid "image: display image only"
msgstr ""

#: ../../../library/tkinter.ttk.rst:196
msgid ""
"top, bottom, left, right: display image above, below, left of, or right of "
