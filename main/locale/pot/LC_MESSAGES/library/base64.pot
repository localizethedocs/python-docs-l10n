msgid "Whether to include enclosing ``<~`` and ``~>`` markers"
msgstr ""

#: ../../../library/base64.rst:217
msgid "Whether to include newline characters"
msgstr ""

#: ../../../library/base64.rst:218
msgid "The set of ASCII characters used for encoding"
msgstr ""

